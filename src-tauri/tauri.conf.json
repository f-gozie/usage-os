{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UsageOS",
  "mainBinaryName": "usage-os",
  "version": "0.1.0",
  "identifier": "com.usageos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "UsageOS",
        "width": 1180,
        "height": 940,
        "minWidth": 760,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-src 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/f-gozie/usage-os/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2NzlCQTc4QzU1QzI4NTIKUldSU0tGekZlTHA1Vm9nWEdWQzdBNnBYVlp0VzdoLzJtM1RuaWFEV3VhOUh0U0hnRU5sZUUrMUcK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["binaries/usageos-ai"],
    "resources": ["THIRD-PARTY-LICENSES.html"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": "dmg-background.tiff",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 180 },
        "applicationFolderPosition": { "x": 480, "y": 180 }
      }
    }
  }
}
